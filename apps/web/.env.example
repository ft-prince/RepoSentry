# ─── apps/web ────────────────────────────────────────────────────────────────
# Copy to .env.local and fill in.
#
# [VERCEL] = also set this in Vercel → Project → Settings → Environment Variables
#            for the deployed dashboard. Vercel does NOT read this file; it
#            injects its own env. Redeploy after changing env vars in Vercel.

# Where the RepoSentry API (apps/api) runs.
# [VERCEL] Set to your deployed apps/api URL (e.g. https://reposentry-api.up.railway.app).
#          Leaving it on localhost on Vercel = dashboard can't reach the API.
API_URL=http://localhost:3001

# Must match API_INTERNAL_TOKEN on apps/api (generate: openssl rand -hex 32)
# [VERCEL] Required for the dashboard to call the API.
API_INTERNAL_TOKEN=

# GitHub OAuth (Auth.js) — OPTIONAL in local dev. When unset, the dashboard
# runs open. Create an OAuth app at https://github.com/settings/developers
# with callback http://localhost:3000/api/auth/callback/github
# [VERCEL] If set, use callback https://<your-app>.vercel.app/api/auth/callback/github
#          and AUTH_SECRET below becomes REQUIRED.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auth.js session encryption secret (generate: openssl rand -base64 32).
# Required when OAuth is configured.
# [VERCEL] REQUIRED on the deployment — missing = 500 FUNCTION_INVOCATION_FAILED.
AUTH_SECRET=

# Public link to your registered GitHub App's install page
# [VERCEL] Optional.
NEXT_PUBLIC_GITHUB_APP_URL=https://github.com/ft-prince/reposentry

# Shows a site-wide "frontend-only preview — backend not deployed" banner.
# [VERCEL] Set to true on the hosted deploy until apps/api is deployed. Leave
#          unset for local/self-host runs so the banner stays hidden.
NEXT_PUBLIC_DEMO_MODE=
