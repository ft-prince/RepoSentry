# ─── apps/api ────────────────────────────────────────────────────────────────
# Copy to .env and fill in. docker-compose values work out of the box for
# DATABASE_URL and REDIS_URL.

# Port the API listens on
PORT=3001

# PostgreSQL connection string (docker-compose default below; Neon/Supabase in prod)
DATABASE_URL=postgresql://reposentry:reposentry@localhost:5432/reposentry

# Redis connection string (docker-compose default below; Upstash in prod)
REDIS_URL=redis://localhost:6379

# Groq API key — free at https://console.groq.com/keys
GROQ_API_KEY=

# Optional model overrides (defaults shown)
# GROQ_REVIEW_MODEL=llama-3.3-70b-versatile
# GROQ_SUMMARY_MODEL=llama-3.1-8b-instant

# GitHub App credentials — from your app's settings page after registering
# (see README "Register the GitHub App")
GITHUB_APP_ID=
# The .pem private key. Either paste with literal \n for newlines, or use a
# multiline value if your host supports it.
GITHUB_PRIVATE_KEY=
# The webhook secret you chose when registering the app
GITHUB_WEBHOOK_SECRET=

# Shared secret between the dashboard and this API (generate: openssl rand -hex 32)
API_INTERNAL_TOKEN=
