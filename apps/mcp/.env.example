# ─── apps/mcp ────────────────────────────────────────────────────────────────
# Only GROQ_API_KEY is required for the review_diff tool. The other tools need
# the database and GitHub App credentials (same values as apps/api).

# Groq API key — free at https://console.groq.com/keys (required)
GROQ_API_KEY=

# Needed by review_pull_request, list_recent_reviews, explain_finding
DATABASE_URL=postgresql://reposentry:reposentry@localhost:5433/reposentry

# Needed by review_pull_request (GitHub App credentials, same as apps/api)
GITHUB_APP_ID=
GITHUB_PRIVATE_KEY=

# HTTP transport (optional): MCP_TRANSPORT=http or pass --http
# MCP_TRANSPORT=stdio
# MCP_PORT=3002
